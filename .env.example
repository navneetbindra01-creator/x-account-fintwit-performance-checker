# =============================================================================
# X Account Fintwit performance checker — environment template
# =============================================================================
# Copy this file to `.env` and replace placeholders with your real values.
# Never commit a real `.env` file.
#
#   copy .env.example .env
# =============================================================================

# xAI API key for optional LLM Long/Short/Neutral classification (--llm)
# Get a key at: https://console.x.ai/
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM model (OpenAI-compatible chat completions on xAI)
LLM_MODEL=grok-4.5

# How many tweets to send per LLM batch (keep modest to avoid empty responses)
LLM_BATCH_SIZE=40

# Optional: force LLM on for every run without passing --llm
# USE_LLM=false

# Optional scrape / OCR caps (defaults shown)
# MAX_OCR_IMAGES=40
# MAX_PARENTS=20
# MAX_CHARTS=30
